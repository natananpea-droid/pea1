# -----------------------------------------------------------------------------
# LifeLine ElectriGuard Environment Variables Template
# Copy this file to .env or .env.local and populate the values below.
# When deploying to Vercel, configure these in your Project Settings.
# -----------------------------------------------------------------------------

# Google Gemini API Key - Required for AI priority assessment of patients based on their medical conditions and equipment list.
GEMINI_API_KEY=

# Google Maps API Key - Required for loading geographic coordinate maps to track vulnerability.
# (If left empty, Google Maps will run in development mode with a watermarked map)
GOOGLE_MAPS_API_KEY=
